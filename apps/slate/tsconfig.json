{
  "extends": "../www/tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../www/src/types/**/*.d.ts",
    "../www/src/app/(app)/examples/slate/**/*.ts",
    "../www/src/app/(app)/examples/slate/**/*.tsx",
    "../../packages/*/src/**/*.d.ts",
    "../../packages/udecode/*/src/**/*.d.ts"
  ],
  "exclude": ["node_modules", "tests"]
}

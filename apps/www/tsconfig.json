{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/.contentlayer/generated": ["./.contentlayer/generated"],
      "@platejs/ai/react": ["../../packages/ai/src/react"],
      "@platejs/basic-nodes/react": ["../../packages/basic-nodes/src/react"],
      "@platejs/basic-styles/react": ["../../packages/basic-styles/src/react"],
      "@platejs/callout/react": ["../../packages/callout/src/react"],
      "@platejs/caption/react": ["../../packages/caption/src/react"],
      "@platejs/code-block/react": ["../../packages/code-block/src/react"],
      "@platejs/code-drawing/react": ["../../packages/code-drawing/src/react"],
      "@platejs/combobox/react": ["../../packages/combobox/src/react"],
      "@platejs/comment/react": ["../../packages/comment/src/react"],
      "@platejs/core/react": ["../../packages/core/src/react"],
      "@platejs/core/static": ["../../packages/core/src/static"],
      "@platejs/date/react": ["../../packages/date/src/react"],
      "@platejs/emoji/react": ["../../packages/emoji/src/react"],
      "@platejs/excalidraw/react": ["../../packages/excalidraw/src/react"],
      "@platejs/indent/react": ["../../packages/indent/src/react"],
      "@platejs/layout/react": ["../../packages/layout/src/react"],
      "@platejs/link/react": ["../../packages/link/src/react"],
      "@platejs/list/react": ["../../packages/list/src/react"],
      "@platejs/list-classic/react": ["../../packages/list-classic/src/react"],
      "@platejs/math/react": ["../../packages/math/src/react"],
      "@platejs/media/react": ["../../packages/media/src/react"],
      "@platejs/mention/react": ["../../packages/mention/src/react"],
      "@platejs/selection/react": ["../../packages/selection/src/react"],
      "@platejs/slash-command/react": [
        "../../packages/slash-command/src/react"
      ],
      "@platejs/suggestion/react": ["../../packages/suggestion/src/react"],
      "@platejs/tabbable/react": ["../../packages/tabbable/src/react"],
      "@platejs/table/react": ["../../packages/table/src/react"],
      "@platejs/tag/react": ["../../packages/tag/src/react"],
      "@platejs/toc/react": ["../../packages/toc/src/react"],
      "@platejs/toggle/react": ["../../packages/toggle/src/react"],
      "@platejs/utils/react": ["../../packages/utils/src/react"],
      "@platejs/yjs/react": ["../../packages/yjs/src/react"],
      "@platejs/*": ["../../packages/*/src"],
      "@udecode/*": ["../../packages/udecode/*/src"],
      "contentlayer/generated": ["./.contentlayer/generated"],
      "platejs": ["../../packages/plate/src/index.tsx"],
      "platejs/react": ["../../packages/plate/src/react"],
      "platejs/static": ["../../packages/plate/src/static"],
      "platejs/*": ["../../packages/plate/src/*"],
      "registry": ["./public/r/registry.json"],
      "registry-shadcn": ["./registry-shadcn.json"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowImportingTsExtensions": true
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.cts",
    "**/*.ctsx",
    "**/*.mts",
    "**/*.mtsx",
    "**/*.js",
    "**/*.jsx",
    "**/*.cjs",
    "**/*.cjsx",
    "**/*.mjs",
    "**/*.mjsx",
    ".next/types/**/*.ts",
    ".contentlayer/generated",
    "../../packages/*/src/**/*.d.ts",
    "../../packages/udecode/*/src/**/*.d.ts",
    "./scripts/**/*.ts",
    "./registry.json"
  ],
  "exclude": [
    "node_modules",
    "__registry__",
    "**/blocks/fumadocs",
    "src/__tests__/package-integration/**/*"
  ]
}

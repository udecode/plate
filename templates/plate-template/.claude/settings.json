{
  "permissions": {
    "allow": ["Bash", "Edit", "Skill", "WebFetch", "WebSearch"]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \".claude/scripts/user-prompt-submit.sh\" ]; then .claude/scripts/user-prompt-submit.sh; fi"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \".claude/scripts/session-start.sh\" ]; then .claude/scripts/session-start.sh; fi"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \".claude/scripts/post-compact.sh\" ]; then .claude/scripts/post-compact.sh; fi"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "debug@dotai": true,
    "dig@dotai": true,
    "dotai@dotai": true,
    "notification@dotai": true,
    "test@dotai": true,
    "frontend-design@claude-plugins-official": true,
    "compound-engineering@every-marketplace": true,
    "lsp-servers@claude-lsp-servers": true,
    "planning-with-files@planning-with-files": true
  },
  "extraKnownMarketplaces": {
    "dotai": {
      "source": {
        "source": "github",
        "repo": "udecode/dotai"
      },
      "autoUpdate": true
    },
    "every-marketplace": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      },
      "autoUpdate": true
    },
    "claude-lsp-servers": {
      "source": {
        "source": "github",
        "repo": "yungweng/claude-lsp-servers"
      },
      "autoUpdate": true
    },
    "planning-with-files": {
      "source": {
        "source": "github",
        "repo": "othmanadi/planning-with-files"
      },
      "autoUpdate": true
    }
  }
}

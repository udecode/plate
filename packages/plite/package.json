{
  "name": "@platejs/plite",
  "version": "54.0.0-beta.0",
  "description": "A completely customizable framework for building rich text editors.",
  "keywords": [
    "canvas",
    "contenteditable",
    "custom",
    "document",
    "edit",
    "editor",
    "html",
    "immutable",
    "markdown",
    "medium",
    "paper",
    "react",
    "rich",
    "richtext",
    "@platejs/plite",
    "text",
    "wysiwyg",
    "wysiwym"
  ],
  "homepage": "https://platejs.org",
  "bugs": {
    "url": "https://github.com/udecode/plate/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/udecode/plate.git",
    "directory": "packages/plite"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal/index.d.ts",
      "import": "./dist/internal/index.js",
      "default": "./dist/internal/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "brl": "echo 'No barrels to generate'",
    "build": "tsdown --config ./tsdown.config.mts --log-level warn",
    "clean": "rimraf dist lib",
    "lint": "plate-pkg p:lint",
    "lint:fix": "plate-pkg p:lint:fix",
    "test": "bun test --preload ../../config/plite-source-test-setup.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "lodash": "^4.17.21",
    "@plate/scripts": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}

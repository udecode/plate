{
  "name": "@platejs/yjs",
  "version": "54.0.0-beta.2",
  "description": "Yjs collaboration bindings for Plite.",
  "keywords": [
    "collaboration",
    "editor",
    "@platejs/plite",
    "yjs"
  ],
  "homepage": "https://platejs.org",
  "bugs": {
    "url": "https://github.com/udecode/plate/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/udecode/plate.git",
    "directory": "packages/yjs"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./internal": {
      "types": "./dist/internal/index.d.ts",
      "import": "./dist/internal/index.js",
      "default": "./dist/internal/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "brl": "echo 'No barrels to generate'",
    "build": "tsdown --config ./tsdown.config.mts --log-level warn",
    "clean": "rimraf dist lib",
    "lint": "plate-pkg p:lint",
    "lint:fix": "plate-pkg p:lint:fix",
    "test": "bun test --preload ../../config/plite-source-test-setup.ts ./test --path-ignore-patterns ''",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "@types/react": "19.2.7",
    "react": "19.2.4",
    "@platejs/plite": "workspace:^",
    "@platejs/plite-history": "workspace:^",
    "@platejs/plite-react": "workspace:^",
    "@plate/scripts": "workspace:*",
    "yjs": "13.6.30"
  },
  "peerDependencies": {
    "react": ">=19.2.0",
    "@platejs/plite": ">=54.0.0-beta.0",
    "@platejs/plite-react": ">=54.0.0-beta.0",
    "yjs": "13.6.30"
  },
  "publishConfig": {
    "access": "public"
  }
}

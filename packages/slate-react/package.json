{
  "name": "@platejs/slate-react",
  "version": "54.0.0-beta.0",
  "description": "Tools for building completely customizable richtext editors with React.",
  "keywords": [
    "canvas",
    "contenteditable",
    "docs",
    "document",
    "edit",
    "editor",
    "editable",
    "html",
    "immutable",
    "markdown",
    "medium",
    "paper",
    "react",
    "rich",
    "richtext",
    "@platejs/slate",
    "text",
    "wysiwyg",
    "wysiwym"
  ],
  "homepage": "https://platejs.org",
  "bugs": {
    "url": "https://github.com/udecode/plate/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/udecode/plate.git",
    "directory": "packages/slate-react"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "brl": "echo 'No barrels to generate'",
    "build": "plate-pkg p:build",
    "clean": "rimraf dist lib",
    "lint": "plate-pkg p:lint",
    "lint:fix": "plate-pkg p:lint:fix",
    "test": "npm run test:vitest",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test:vitest": "vitest run --config ./vitest.config.mjs"
  },
  "dependencies": {
    "@juggle/resize-observer": "^3.4.0",
    "@platejs/slate-history": "workspace:^",
    "@tanstack/react-virtual": "^3.13.25",
    "lodash": "^4.17.21",
    "react-compiler-runtime": "^1.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/lodash": "^4.14.200",
    "@types/node": "24.12.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "jsdom": "20.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@platejs/slate": "workspace:^",
    "@platejs/slate-dom": "workspace:^",
    "@platejs/slate-hyperscript": "workspace:^",
    "vitest": "^4.1.0",
    "@plate/scripts": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19.2.0",
    "react-dom": ">=19.2.0",
    "@platejs/slate": ">=54.0.0-beta.0",
    "@platejs/slate-dom": ">=54.0.0-beta.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

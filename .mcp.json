{
  "mcpServers": {
    "plate": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"],
      "env": {
        "REGISTRY_URL": "http://localhost:3000/rd/registry.json"
      },
      "type": "stdio"
    },
    "agentation": {
      "command": "npx",
      "args": ["-y", "agentation-mcp@latest", "server"],
      "type": "stdio"
    }
  }
}
